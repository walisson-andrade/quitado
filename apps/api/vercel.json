{
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile && pnpm --filter @quitado/shared-types --filter @quitado/calc --filter @quitado/core build",
  "functions": {
    "api/**/*.ts": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/handler?slug=$1" }
  ]
}
