# --- Banco de dados (Supabase — usado em dev e produção) ---
# Project Settings -> Database -> Connection string -> "Transaction pooler" (porta 6543) ou "Session pooler" (5432)
DATABASE_URL=postgresql://postgres.xxxxxxxx:SENHA@aws-x-xxxx.pooler.supabase.com:5432/postgres

# --- Docker dev local (docker-compose.yml lê estas variáveis do shell) ---
JWT_SECRET=troque-por-um-segredo-longo-aleatorio
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# --- Login via Google (console.cloud.google.com -> APIs & Services -> Credentials) ---
# Tela de consentimento em modo "Testing", com os emails das ~5 pessoas em "Test users"
# — evita a revisão de app do Google, já que não é um app público.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Callback registrado no client OAuth do Google. Em dev, a API roda em :3011 mas o
# navegador acessa via Vite (:5173) que faz proxy de /api -> api-dev.
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback
WEB_ORIGIN=http://localhost:5173

# --- Produção (Vercel) — configurar como env vars do projeto na Vercel ---
# DATABASE_URL=...                   (mesma connection string do Supabase)
# BLOB_READ_WRITE_TOKEN=...          (integração Vercel Blob preenche automaticamente)
# JWT_SECRET=...
# GEMINI_API_KEY=...
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_REDIRECT_URI=https://<seu-projeto-api>.vercel.app/api/auth/google/callback
# WEB_ORIGIN=https://<seu-projeto-web>.vercel.app
